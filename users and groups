## ------------------------------------------------------
## create a group named sharedgroup
## add the user student101 with no login shell
## add the user student102 as a member of sharedgroup
## add user student103 as a member of sharedgroup with uuid 4444
## all user passwords are: Password123
## change student102's password to Amazing25
## remove student102 from sharedgroup

getent group sharedgroup
groupadd sharedgroup

useradd -s /sbin/nologin student101
useradd -G sharedgroup student102
useradd -u 4444 -G sharedgroup student103

id student101
id student102
id student103

for user in student101 student102 student103; do echo Password123 | passwd --stdin $user; done

#echo student101:Password123 | chpasswd
#echo student102:Password123 | chpasswd
#echo student103:Password123 | chpasswd

echo student102:Amazing25 | chpasswd

gpasswd -d student102 sharedgroup

getent group sharedgroup



