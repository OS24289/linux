## create a directory with the following details
## dir: /home/collab
## group owner: sales
## dir should be readable and writeable to members of sales group but no other user besides root
## files created in dir automatically have group ownership to sales group

groupadd sales
mkdir -p /home/collab
ll /home/collab
chgrp sales /home/collab
ll /home/collab
chmod 770 /home/collab
ll /home/collab
chmod 2770 /home/collab
ll /home/collab
touch /home/collab/file1
ll /home/collab




