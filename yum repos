vi /etc/yum.repos.d/example.repo


[BaseOS]
name=BaseOS
baseurl=http://repo.example.com/rhel/10/BaseOS
enabled=1
gpgcheck=0

[AppStream]
name=AppStream
baseurl=http://repo.example.com/rhel/10/AppStream
enabled=1
gpgcheck=0


[repository-id]
name=Example Repository
baseurl=http://repo.example.com/rhel/10/
enabled=1
gpgcheck=1
gpgkey=http://repo.example.com/rhel/10/RPM-GPG-KEY



