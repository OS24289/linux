##-- autofs

# configure autofs to mount an NFS export
# server: 172.10.10.103 /home/guests/netuserx
# client: 172.10.10.101 /share/netuserx
# user: netuserx
# pass: netuserx
# requirement: must persist reboots

# server
mkdir /home/guests
useradd -m -d /home/guests/netuserx netuserx
passwd netuserx

dnf install nfs-utils -y
systemctl enable --now nfs-server

vi /etc/exports
/home/guests/netuserx 172.10.10.101(rw,sync,mo_root_squash)

firewall-cmd --add-service=nfs --permanent
firewall-cmd --add-service=mountd --permanent
firewall-cmd --add-service=rpc.bin --permanent
firewall-cmd --reload
systmctl restart firewalld

exportfs -raw


# client

